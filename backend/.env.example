# ─────────────────────────────────────────────
# Stephanie Miranda — Backend Configuration
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=production

# JWT — use a long, random string in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Database
DB_PATH=./database/app.db

# Frontend URL (used for CORS and email links)
FRONTEND_URL=https://stmiranda.com

# Admin user created on first run (change password immediately after deploy)
ADMIN_EMAIL=stephanie@stmiranda.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Stephanie Miranda

# ─────────────────────────────────────────────
# Email — Resend (https://resend.com)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address — must match a verified domain in your Resend account
# For testing only: Stephanie Miranda <onboarding@resend.dev>
EMAIL_FROM=Stephanie Miranda <noreply@stmiranda.com>

# ─────────────────────────────────────────────
# Google Calendar (optional)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://stmiranda.com/api/calendar/auth/callback
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./config/service-account-key.json
